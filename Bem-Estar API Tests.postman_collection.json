    {
      "name": "4 + 4.1 - GET/desafio/{id}",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Verificando retorno de status em login autorizado\", function() {\r",
              "    pm.response.to.have.status(200)\r",
              "})\r",
              "pm.test(\"Validando campos que foram gerados dentro do desafio\", function() {\r",
              "    const response = pm.response.json()\r",
              "    pm.expect(response).to.have.property('id')\r",
              "    pm.expect(response).to.have.property('activity')\r",
              "    pm.expect(response).to.have.property('total_activities')\r",
              "    \r",
              "    /* Campo que nao existe e vai retornar um erro : */\r",
              "    pm.expect(response).to.have.property('category')\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
