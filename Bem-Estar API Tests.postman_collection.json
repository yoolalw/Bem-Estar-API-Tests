    {
      "name": "1 - GET/status",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Verificando retorno de status da api\", function() {\r",
              "    pm.response.to.have.status(200)\r",
              "})\r",
              "\r",
              "pm.test(\"Verificando tempo de resposta da api\", function(){\r",
              "    pm.expect(pm.response.responseTime).to.be.below(50)\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/status",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "status"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2 - POST/users",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Verificando se o retorno foi de 201 ou 200\", function(){\r",
              "    pm.expect(pm.response.code).to.have.oneOf([200, 201])\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const random = Math.floor(Math.random() * 10000)\r",
              "pm.variables.set(\"novo_usuario\", \"user-\" + random)\r",
              "pm.variables.set(\"nova_senha\", \"senha\")\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"username\": \"{{novo_usuario}}\",\r\n    \"password\": \"{{nova_senha}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
